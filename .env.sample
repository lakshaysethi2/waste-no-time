# Telegram bot token. Also used to verify Telegram Login Widget payloads.
TELEGRAM_BOT_API_KEY=replace-with-your-bot-token

# Django production configuration. Generate a unique value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(50))"`.
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000

# Reject Telegram Login Widget payloads older than this value (seconds).
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
# Public bot username used by the Telegram Login Widget (without @).
VITE_TELEGRAM_BOT_USERNAME=your_bot_username
